# Mercado Livre API Credentials
# Get these from https://developers.mercadolivre.com.br/
ML_PIPE_MERCADO_LIVRE_CLIENT_ID=your_client_id_here
ML_PIPE_MERCADO_LIVRE_CLIENT_SECRET=your_client_secret_here
ML_PIPE_MERCADO_LIVRE_REDIRECT_URI=http://localhost:8000/callback

# Optional: Token file path
ML_PIPE_MERCADO_LIVRE_TOKEN_PATH=tokens.json

# Token storage mode (default is secure/encrypted)
# Set to 0 only if you need explicit plaintext fallback.
ML_PIPE_MERCADO_LIVRE_USE_SECURE_STORAGE=1

# Auto-migrate tokens.json -> tokens.json.enc when secure mode is active
ML_PIPE_MERCADO_LIVRE_AUTO_MIGRATE_TOKENS=1

# Optional encryption key (recommended for CI/non-interactive environments)
# ML_PIPE_ENCRYPTION_KEY=your_fernet_or_password_key_here
